{
  "id": null,
  "uid": "best-model-dashboard",
  "title": "Best Model Metrics",
  "tags": ["model", "metrics"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Model Version",
      "gridPos": {"x": 0, "y": 0, "w": 3, "h": 4},
      "datasource": "PostgreSQL",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT run_date as time, model_version as value FROM best_model_metrics ORDER BY accuracy DESC LIMIT 1;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Year",
      "gridPos": {"x": 3, "y": 0, "w": 3, "h": 4},
      "datasource": "PostgreSQL",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT run_date as time, year as value FROM best_model_metrics ORDER BY accuracy DESC LIMIT 1;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Accuracy",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": "PostgreSQL",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT run_date as time, accuracy as value FROM best_model_metrics ORDER BY accuracy DESC LIMIT 1;",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Precision (Macro Avg)",
      "gridPos": {"x": 0, "y": 4, "w": 6, "h": 4},
      "datasource": "PostgreSQL",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT run_date as time, precision_macro_avg as value FROM best_model_metrics ORDER BY accuracy DESC LIMIT 1;",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Recall (Macro Avg)",
      "gridPos": {"x": 6, "y": 4, "w": 6, "h": 4},
      "datasource": "PostgreSQL",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT run_date as time, recall_macro_avg as value FROM best_model_metrics ORDER BY accuracy DESC LIMIT 1;",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
