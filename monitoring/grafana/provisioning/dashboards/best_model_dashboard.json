      "title": "F1 Score (Macro Avg)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 4},
      "datasource": "PostgreSQL",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT run_date as time, f1_macro_avg as value FROM best_model_metrics ORDER BY accuracy DESC LIMIT 1;",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
